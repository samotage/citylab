# CityLab environment variables — TEMPLATE.
# Copy to .env (gitignored — never commit real secrets) and fill in values:
#     cp .env.example .env
# Loaded automatically by run_citylab.py (server) and the flask CLI.

# Flask session signing key — generate with:
#     python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# REST API bearer token (Authorization: Bearer <token>) used by cli-citylab/agents
CITYLAB_API_TOKEN=dev-token-changeme

# Solcast solar API key — real live+forecast feed (refresh on demand:
#   flask --app citylab:create_app solcast-refresh)
SOLCAST_API_KEY=your-solcast-api-key

# Optional — OpenNEM public endpoints work without a key
# OPENNEM_API_KEY=

# Admin seed credentials (flask seed-admin)
CITYLAB_ADMIN_EMAIL=admin@citylab.local
CITYLAB_ADMIN_PASSWORD=changeme

# Database (optional — overrides config.yaml; leave unset to use defaults)
# DATABASE_URL=postgresql://localhost/citylab

# Headspace integration (optional)
# HEADSPACE_URL=http://127.0.0.1:5001
# HEADSPACE_API_TOKEN=
