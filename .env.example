# CityLab environment variables
# Copy to .env and fill in values

# Database (overrides config.yaml)
# DATABASE_URL=postgresql://localhost/citylab

# Admin seed credentials
CITYLAB_ADMIN_EMAIL=admin@citylab.local
CITYLAB_ADMIN_PASSWORD=changeme

# API token for CLI/agent access
# CITYLAB_API_TOKEN=

# Flask
FLASK_APP=src/citylab
FLASK_ENV=development

# Headspace integration
# HEADSPACE_URL=http://127.0.0.1:5001
# HEADSPACE_API_TOKEN=
